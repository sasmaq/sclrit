        "@nextcloud/files": "^3.10.2",
        "@nextcloud/l10n": "^3.2.0",
        "@nextcloud/password-confirmation": "^5.3.2",
        "@nextcloud/router": "^3.0.1",
        "@nextcloud/vue": "^8.23.1",
        "vue": "^2.7.16"
    },
    "devDependencies": {
        "@nextcloud/eslint-config": "^9.0.1",
        "@nextcloud/vite-config": "^1.7.2",
        "@vitejs/plugin-vue2": "^2.3.4",
        "@vue/test-utils": "^1.3.6",
        "eslint": "^10.6.0",
        "jsdom": "^29.1.1",
        "sass": "^1.80.0",
        "typescript": "^5.6.3",
        "vite": "^7.1.10",
